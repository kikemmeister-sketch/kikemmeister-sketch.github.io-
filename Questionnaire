'use client';

import Link from 'next/link';
import { useState } from 'react';

const ideas = [
  {
    interest: 'sport',
    title: 'Expérience sportive',
    text: 'Une session d’escalade, un billet de match ou un cours privé pour progresser.',
    icon: '01',
  },
  {
    interest: 'lecture',
    title: 'Coffret lecture',
    text: 'Une sélection de livres avec un marque-page personnalisé et une boisson douce.',
    icon: '02',
  },
  {
    interest: 'cuisine',
    title: 'Atelier gourmand',
    text: 'Un cours de cuisine, un kit pâtisserie ou une dégustation à partager.',
    icon: '03',
  },
  {
    interest: 'bien-etre',
    title: 'Pause bien-être',
    text: 'Un massage, une box détente ou une journée calme dans un spa accessible.',
    icon: '04',
  },
  {
    interest: 'creation',
    title: 'Moment créatif',
    text: 'Un atelier poterie, photo, peinture ou un beau kit pour créer à la maison.',
    icon: '05',
  },
];

const occasions = {
  anniversaire: 'Anniversaire',
  noel: 'Noël',
  amour: 'Couple',
  merci: 'Remerciement',
};

const relations = {
  ami: 'ami(e)',
  famille: 'membre de la famille',
  partenaire: 'partenaire',
  collegue: 'collègue',
};

export default function Questionnaire() {
  const [interest, setInterest] = useState('sport');
  const [budget, setBudget] = useState(50);
  const [occasion, setOccasion] = useState('anniversaire');
  const [relation, setRelation] = useState('ami');
  const result = ideas.find((i) => i.interest === interest) ?? ideas[0];
  const secondaryIdeas = ideas.filter((idea) => idea.interest !== interest).slice(0, 2);

  return (
    <main className="questionnaire">
      <nav className="topBar">
        <Link className="brand" href="/">
          InspiCadeau
        </Link>
        <Link className="ghostButton" href="/">
          Accueil
        </Link>
      </nav>

      <section className="questionnaireIntro">
        <p className="eyebrow">Questionnaire cadeau</p>
        <h1>Une idée plus juste en quelques choix.</h1>
        <p>
          Ajustez le profil, le budget et l’occasion. Les suggestions se mettent à jour
          immédiatement.
        </p>
      </section>

      <section className="builder">
        <form className="formPanel">
          <div className="field">
            <label htmlFor="relation">Pour qui ?</label>
            <select id="relation" value={relation} onChange={(e) => setRelation(e.target.value)}>
              <option value="ami">Un(e) ami(e)</option>
              <option value="famille">La famille</option>
              <option value="partenaire">Mon/ma partenaire</option>
              <option value="collegue">Un(e) collègue</option>
            </select>
          </div>

          <div className="field">
            <label htmlFor="occasion">Occasion</label>
            <select id="occasion" value={occasion} onChange={(e) => setOccasion(e.target.value)}>
              <option value="anniversaire">Anniversaire</option>
              <option value="noel">Noël</option>
              <option value="amour">Couple</option>
              <option value="merci">Remerciement</option>
            </select>
          </div>

          <div className="field">
            <label htmlFor="interest">Centre d’intérêt</label>
            <select id="interest" value={interest} onChange={(e) => setInterest(e.target.value)}>
              <option value="sport">Sport</option>
              <option value="lecture">Lecture</option>
              <option value="cuisine">Cuisine</option>
              <option value="bien-etre">Bien-être</option>
              <option value="creation">Création</option>
            </select>
          </div>

          <div className="field">
            <div className="budgetLine">
              <label htmlFor="budget">Budget</label>
              <span>{budget} €</span>
            </div>
            <input
              id="budget"
              type="range"
              min="10"
              max="250"
              step="5"
              value={budget}
              onChange={(e) => setBudget(Number(e.target.value))}
            />
          </div>
        </form>

        <div>
          <div className="resultsHeader">
            <div>
              <p className="eyebrow">Suggestions</p>
              <h2>Pour un {relations[relation as keyof typeof relations]}</h2>
            </div>
            <span className="pill">
              {occasions[occasion as keyof typeof occasions]} · {budget} €
            </span>
          </div>

          <div className="resultsGrid">
            {[result, ...secondaryIdeas].map((idea, index) => (
              <article className="resultCard" key={`${idea.interest}-${index}`}>
                <div className="resultIcon">{idea.icon}</div>
                <div>
                  <h3>{index === 0 ? idea.title : `Alternative : ${idea.title}`}</h3>
                  <p>{idea.text}</p>
                </div>
                <strong>{index === 0 ? 'Meilleur choix' : 'Option complémentaire'}</strong>
              </article>
            ))}
          </div>
        </div>
      </section>
    </main>
  );
